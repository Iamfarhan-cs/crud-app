PORT=8080
DATABASE_URL=postgres://crud_user:crud_password@localhost:5432/crud_db?sslmode=disable

READ_TIMEOUT=5s
WRITE_TIMEOUT=10s
IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=10s

DB_MAX_OPEN_CONNECTIONS=10
DB_MAX_IDLE_CONNECTIONS=5
DB_CONNECTION_MAX_LIFE=30m

POSTGRES_DB=crud_db
POSTGRES_USER=crud_user
POSTGRES_PASSWORD=crud_password
